# --- Android local builds (npm scripts use dotenv-cli) ---
# `.env.dev` / `.env.release` are loaded first, then this file fills in the rest.
# Copy this file to `.env` and fill in secrets. Keep `.env.dev` / `.env.release` as committed defaults.

EXPO_PUBLIC_API_URL=
EXPO_PUBLIC_AUTH0_CLIENT_ID=
EXPO_PUBLIC_AUTH0_DOMAIN=
EXPO_PUBLIC_AUTH0_AUDIENCE=
EXPO_PUBLIC_AUTH0_NONCE=